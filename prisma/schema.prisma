generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum CategoryType {
  income
  outcome
}

enum WalletKind {
  basic
  goal
}

model MonthlyBudget {
  id        Int    @id @default(autoincrement())
  name      String
  amount    Int
  month     String
  category  String
  type      String // 'income' | 'outcome' | 'carryover'
  sortOrder Int    @default(0)
}

model Wallet {
  id               Int    @id @default(autoincrement())
  name             String @unique
  balance          Int    @default(0)
  excludeFromTotal Boolean @default(false)
  walletKind       WalletKind @default(basic)
  goalAmount       Int?
  goalStartMonth   String?
  goalDueMonth     String?
  sortOrder        Int    @default(0)
}

model Category {
  id              Int          @id @default(autoincrement())
  name            String
  type            CategoryType
  parentId        Int?
  parent          Category?    @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children        Category[]   @relation("CategoryHierarchy")
  cashLogs        CashLog[]

  @@index([parentId])
  @@unique([name, type, parentId])
}

model CashLog {
  id          Int    @id @default(autoincrement())
  date        String
  description String
  amount      Int
  walletName  String
  categoryId  Int?
  excludeFromReport Boolean @default(false)
  category    Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([categoryId])
}
